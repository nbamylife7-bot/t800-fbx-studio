# Copy to .env and adjust paths on your server.

T800_WEB_HOST=0.0.0.0
T800_WEB_PORT=8080
T800_WEB_ENV=gmr

# Parent repo (cyanpuppets) — demo PKL clips live in $CYANPUPPETS_ROOT/out
CYANPUPPETS_ROOT=/opt/cyanpuppets

# GMR retargeting backend (must contain assets/t800, general_motion_retargeting, scripts/)
GMR_ROOT=/opt/cyanpuppets/Новая папка 8/GMR

# Optional: extra demo .pkl directory
T800_DEMO_DIR=/opt/cyanpuppets/out
