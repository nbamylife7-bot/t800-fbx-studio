# Copy to .env and adjust if needed (optional — defaults work for GitHub clone).

T800_WEB_HOST=0.0.0.0
T800_WEB_PORT=8080
T800_WEB_ENV=t800-studio

# Bundled backend (default: ./gmr inside repo)
# GMR_ROOT=/path/to/t800-fbx-studio/gmr

# Optional demo PKL directory
# T800_DEMO_DIR=/path/to/demo/pkl

# FBX SDK (set after ./scripts/download_fbx_sdk.sh)
# FBXSDK_ROOT=/path/to/FBX SDK/2020.3.7
# FBX_BINDINGS_DIR=/path/to/FBXPythonBindings

# Auto-download FBX SDK during ./install.sh (~100 MB)
# T800_AUTO_DOWNLOAD_FBX=1
