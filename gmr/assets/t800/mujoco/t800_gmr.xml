  <option gravity="0 0 -9.81" timestep="0.005" />
  <!--
    这是一份专门给 GMR 使用的 T800 简化模型：
    1. 根节点是 floating-base，自带 freejoint，满足 GMR 的 qpos 假设：root(7) + joints。
    2. body / joint 名字严格沿用训练侧 T800 语义，方便后续把重定向结果对回训练链。
    3. 这里只保留 IK 与可视化需要的主链刚体，不直接复用训练用 URDF，避免影响训练资产。
    4. 当前版本使用 proxy geoms 表达链路形状；如果后续要换成真实外观 mesh，保持相同 body / joint 命名即可。
  -->
  <default>
    <joint damping="1.0" armature="0.01" limited="true" />
    <geom type="capsule" size="0.03" rgba="0.78 0.78 0.82 1" />
    <default class="visual_mesh">
      <geom type="mesh" contype="0" conaffinity="0" density="0" group="2" rgba="0.82 0.82 0.86 1" />
    </default>
    <default class="collision_proxy">
      <geom group="3" rgba="1 0.5 0 0" contype="1" conaffinity="1" />
    </default>
  </default>
